                <zone fixed-size='280' h='23342' id='13' is-fixed='true' name='Attrition by Job Satisfaction' w='45242' x='6662' y='45663'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
